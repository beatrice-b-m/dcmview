{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run dcmview VS Code Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/vscode"
      ],
      "outFiles": [
        "${workspaceFolder}/vscode/out/**/*.js"
      ],
      "preLaunchTask": "dcmview-vscode: compile"
    }
  ]
}
