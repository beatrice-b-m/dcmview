{
  "name": "dcmview-vscode",
  "displayName": "dcmview",
  "description": "Open DICOM files and folders in dcmview from VS Code.",
  "version": "0.2.0",
  "private": true,
  "publisher": "dcmview",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/beatrice-b-m/dcmview.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:dcmview.openPath",
    "onCommand:dcmview.openWorkspaceSelection",
    "onCommand:dcmview.stopAll"
  ],
  "contributes": {
    "commands": [
      {
        "command": "dcmview.openPath",
        "title": "Open with dcmview",
        "category": "dcmview"
      },
      {
        "command": "dcmview.openWorkspaceSelection",
        "title": "Open Workspace with dcmview",
        "category": "dcmview"
      },
      {
        "command": "dcmview.stopAll",
        "title": "Stop All dcmview Sessions",
        "category": "dcmview"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "dcmview.openPath",
          "group": "navigation@50"
        }
      ]
    },
    "configuration": {
      "title": "dcmview",
      "properties": {
        "dcmview.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the dcmview binary. When empty, the extension tries the repo debug binary, bundled closed-test binaries, and then PATH."
        },
        "dcmview.defaultRecursive": {
          "type": "boolean",
          "default": true,
          "description": "Search selected folders recursively when opening them with dcmview."
        },
        "dcmview.extraArgs": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional command-line arguments passed to dcmview before selected paths."
        },
        "dcmview.startupTimeoutSeconds": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "description": "Seconds to wait for dcmview to report its local server URL."
        },
        "dcmview.terminalInterception.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Route dcmview and dcmview-py commands launched from new integrated terminals into VS Code webview panels."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "test": "npm run compile && node ./out/test/runTest.js",
    "stage:binaries": "python3 ../scripts/stage_vscode_binaries.py",
    "package": "npm run compile && vsce package --no-dependencies --out ../dist/dcmview-vscode-${npm_package_version}.vsix",
    "package:release": "npm run stage:binaries -- --artifacts-dir ../artifacts && npm run package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.14.11",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.9.2",
    "mocha": "^11.3.0",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "serialize-javascript": "7.0.5"
  }
}
